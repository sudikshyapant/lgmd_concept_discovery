#!/bin/sh
# Strip the malformed ipywidgets state that Colab writes into notebooks
# (metadata.widgets without a "state" key), which makes GitHub refuse to render them:
#   "Invalid Notebook ... the 'state' key is missing from 'metadata.widgets'".
# Runs on every commit; cleans each staged .ipynb and re-stages it.
for nb in $(git diff --cached --name-only --diff-filter=ACM | grep '\.ipynb$'); do
    [ -f "$nb" ] || continue
    python3 - "$nb" <<'PY'
import json, sys
path = sys.argv[1]
with open(path) as f:
    nb = json.load(f)
changed = nb.get("metadata", {}).pop("widgets", None) is not None
for cell in nb.get("cells", []):
    if cell.get("metadata", {}).pop("widgets", None) is not None:
        changed = True
if changed:
    with open(path, "w") as f:
        json.dump(nb, f, indent=1)
        f.write("\n")
    print(f"[pre-commit] stripped metadata.widgets from {path}")
PY
    git add "$nb"
done
